# ── Required ──────────────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Serper.dev API key for richer Google search results (https://serper.dev)
# Leave blank to use free DuckDuckGo scraping fallback
SERPER_API_KEY=

# ── JWT ───────────────────────────────────────────────────────────────────────
# CHANGE THIS to a long random string in production!
JWT_SECRET_KEY=change-me-in-production-super-secret-key-2024
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600
